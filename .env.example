# Cadena de conexión de MongoDB Atlas (gratis)
MONGO_URI=mongodb+srv://usuario:password@cluster0.xxxxx.mongodb.net/encogelo?retryWrites=true&w=majority

# Opcional: si lo dejas vacío, el servidor usa automáticamente el dominio de la petición
BASE_URL=

# Puerto local (Render lo asigna solo en producción)
PORT=3000
